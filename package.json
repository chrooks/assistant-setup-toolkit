{
  "name": "code-assistant-context",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "loop-audit:extract": "tsx scripts/loop-audit.ts",
    "sync": "npm run setup -- --sync",
    "sync:watch": "chokidar 'canonical/**/*' 'manifests/**/*' -c 'npm run sync' --initial",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "chokidar-cli": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  }
}
